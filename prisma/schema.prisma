// Home Dining — multi-tenant room-service ordering.
// Dev uses SQLite (zero-config). For production, switch `provider` to
// "postgresql" and point DATABASE_URL at Postgres; the schema is kept
// portable (money as integer paise, status as string, no db-specific types).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Platform-wide billing settings (a single row, id = "platform").
model PlatformSettings {
  id                 String  @id @default("platform")
  defaultAmountPaise Int     @default(50000) // ₹500/month default
  adminUpiId         String? // where hotels pay their subscription
}

/// A tenant. Each hotel gets its own branded storefront at /{slug}.
model Hotel {
  id         String   @id @default(cuid())
  slug       String   @unique // URL segment, e.g. "grand-majestic"
  name       String
  tagline    String   @default("Delivered to your door")
  // Branding
  logoText   String? // 2-letter monogram shown when there's no logo image
  logoUrl    String? // optional uploaded logo
  themeColor String   @default("#B8860B") // primary (gold by default)
  accentColor String  @default("#1a1a2e") // header / hero (navy by default)
  // Operations
  gstPercent Int      @default(5) // tax rate applied at checkout
  etaMinutes String   @default("20–35") // estimated delivery shown to guests
  prepMinutes Int     @default(30) // default preparation time for order tracking
  currency   String   @default("INR")
  // Payments — the hotel's own UPI ID; guests pay via a dynamic UPI QR and
  // staff verify the payment in their UPI app before confirming the order.
  upiId      String?
  // Three credentials per hotel, all set at onboarding, editable by the manager.
  passwordHash      String? // manager password (full dashboard)
  staffPasswordHash String? // staff password (orders-only view)
  guestCode         String? @unique // code guests enter to reach the menu
  managerEmail      String? // for password reset
  // Online payment gateway (Razorpay) — the hotel's own keys, so real
  // payments confirm automatically and settle to the hotel's account.
  razorpayKeyId     String?
  razorpayKeySecret String?
  // Password-reset link (hash of a one-time token + its expiry).
  resetTokenHash      String?
  resetTokenExpiresAt DateTime?
  // Subscription billing. Trial = createdAt + 45 days (computed). paidUntil
  // tracks the end of the paid period; each payment extends it by a month.
  paidUntil               DateTime?
  subscriptionAmountPaise Int? // per-hotel override; null = platform default
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  categories Category[]
  menuItems  MenuItem[]
  orders     Order[]
}

model Category {
  id        String   @id @default(cuid())
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name      String
  icon      String   @default("🍽️") // emoji shown on tab + section heading
  sortOrder Int      @default(0)

  items MenuItem[]

  @@index([hotelId])
}

model MenuItem {
  id           String   @id @default(cuid())
  hotelId      String
  hotel        Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name         String
  description  String   @default("")
  priceInPaise Int // store money as integer paise to avoid float errors
  imageUrl     String?
  isVeg        Boolean  @default(true)
  isAvailable  Boolean  @default(true)
  sortOrder    Int      @default(0)

  orderItems OrderItem[]

  @@index([hotelId])
  @@index([categoryId])
}

/// A guest order. Status is a string (portable across DBs):
/// PENDING -> PAID -> PREPARING -> DELIVERED (or CANCELLED).
model Order {
  id              String   @id @default(cuid())
  hotelId         String
  hotel           Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomNumber      String
  guestName       String?
  status          String   @default("PENDING")
  subtotalInPaise Int
  taxInPaise      Int
  totalInPaise    Int
  note            String? // guest instructions
  // Guest's claimed UPI transaction ID (UTR); null for "pay at reception".
  paymentRef        String?
  // Set when staff verify the payment (also = "confirmed by kitchen" time).
  paymentVerifiedAt DateTime?
  // Order-tracking timeline milestones (set as staff advance the order).
  preparingAt       DateTime? // "Preparing your food" reached
  outForDeliveryAt  DateTime? // "On the way to your room" reached
  deliveredAt       DateTime? // "Delivered" reached
  // Staff override of the estimated prep time for this one order (minutes).
  etaOverrideMinutes Int?
  createdAt       DateTime @default(now())

  items OrderItem[]

  @@index([hotelId])
  @@index([status])
}

/// Line item on an order. Name and price are snapshotted so historical
/// orders remain correct even if the menu changes later.
model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId    String?
  menuItem      MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  nameSnapshot  String
  priceInPaise  Int
  quantity      Int

  @@index([orderId])
}
